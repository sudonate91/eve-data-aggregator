# ============================================================
# Local development environment
# Copy this to .env when working locally:
#   cp .env.dev .env
#
# DB_HOST=eve-mysql     → use when running app inside Docker (docker compose dev)
# DB_HOST=127.0.0.1     → use when running app with 'node bin/index.mjs' directly
#                          and MySQL is running via: docker compose -f docker-compose.yml
#                          -f docker-compose.dev.yml up eve-mysql
# ============================================================

# EVE Online ESI — fill in your real creds
CLIENT_ID=7e42742a49e449c190b57ee5ba4d1a3b
# For local dev the callback must point to the auth server running in this process
CALLBACK_URL=https://localhost:3000/callback
SCOPE=esi-wallet.read_corporation_wallets.v1 esi-contracts.read_corporation_contracts.v1
STATE=unique-state

# Your corp IDs
CORPORATION_ID=98399918
STRUCT_CORPORATION_ID=98782550
VEN0M_CORPORATION_ID=98641692
KRYTEK_CORPORATION_ID=98782550
S0B_MART_CORPORATION_ID=98782550

JANICE_API_KEY=

# Auth web UI port (open http://localhost:3000 to authenticate corps)
AUTH_PORT=3000

# Database — when running node directly against the dev MySQL container on port 3307
# use 127.0.0.1; when running inside docker compose use eve-mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=S0b_Admin
DB_PASSWORD=devpassword
DB_NAME=S0b
S0b_STRUCT_DB_NAME=S0b_Struct
VEN0M_DB_NAME=Ven0m
KRYTEK_DB_NAME=KryTek
S0B_MART_DB_NAME=S0b_Mart

# Dev MySQL container root password (simple is fine locally)
MYSQL_ROOT_PASSWORD=devroot
ROOT_USER=root
ROOT_PASSWORD=devroot

# Read-only user — leave blank to reuse DB_PASSWORD
MYSQL_READONLY_PASSWORD=

# App behaviour
USE_ENV_CONFIG=true
RUN_INTERVAL_MINUTES=5

# Enable only what you're working on locally
ENABLE_S0B_WALLET=false
ENABLE_S0B_STRUCT_WALLET=false
ENABLE_VEN0M_WALLET=false
ENABLE_KRYTEK_WALLET=false
ENABLE_S0B_MART_WALLET=true
ENABLE_S0B_STRUCT_CONTRACTS=false
ENABLE_CSV_IMPORT=false
