<?xml version="1.0"?>
<Container version="2">
  <Name>eve-data-aggregator</Name>
  <Repository>sudonate91/eve-data-aggregator:latest</Repository>
  <Registry>https://hub.docker.com/r/sudonate91/eve-data-aggregator</Registry>
  <Network>host</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/sudonate91/eve-data-aggregator</Support>
  <Project>https://github.com/sudonate91/eve-data-aggregator</Project>
  <Overview>EVE Online Data Aggregator - CLI tool for importing corporation wallet and contract data from EVE Online ESI API to MySQL databases.</Overview>
  <Category>Tools:</Category>
  <WebUI/>
  <TemplateURL>https://raw.githubusercontent.com/sudonate91/eve-data-aggregator/main/unraid-template.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/sudonate91/eve-data-aggregator/main/icon.png</Icon>
  <ExtraParams>-it</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled></DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="EVE Client ID" Target="CLIENT_ID" Default="" Mode="" Description="Your EVE Online ESI Application Client ID" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Callback URL" Target="CALLBACK_URL" Default="https://localhost/callback/" Mode="" Description="OAuth callback URL (must match ESI app configuration)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="ESI Scope" Target="SCOPE" Default="esi-wallet.read_corporation_wallets.v1 esi-contracts.read_corporation_contracts.v1" Mode="" Description="ESI API scopes (space-separated)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="OAuth State" Target="STATE" Default="" Mode="" Description="OAuth state parameter for security" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Main Corporation ID" Target="CORPORATION_ID" Default="" Mode="" Description="Main corporation ID (S0b Holdings)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Structure Corp ID" Target="STRUCT_CORPORATION_ID" Default="" Mode="" Description="Structure Management corporation ID" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Ven0m Corporation ID" Target="VEN0M_CORPORATION_ID" Default="" Mode="" Description="Ven0m corporation ID" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="KryTek Corporation ID" Target="KRYTEK_CORPORATION_ID" Default="" Mode="" Description="KryTek corporation ID" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="S0b Mart Corporation ID" Target="S0B_MART_CORPORATION_ID" Default="" Mode="" Description="S0b Mart corporation ID" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Janice API Key" Target="JANICE_API_KEY" Default="" Mode="" Description="Janice API key for price checking" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="Database Host" Target="DB_HOST" Default="" Mode="" Description="MySQL database server IP (use localhost or 127.0.0.1 for Unraid host)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Database User" Target="DB_USER" Default="" Mode="" Description="MySQL database username" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Database Password" Target="DB_PASSWORD" Default="" Mode="" Description="MySQL database password" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="Main Database Name" Target="DB_NAME" Default="S0b" Mode="" Description="Main database name" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Struct Database Name" Target="S0b_STRUCT_DB_NAME" Default="S0b_Struct" Mode="" Description="Structure management database name" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Ven0m Database Name" Target="VEN0M_DB_NAME" Default="Ven0m" Mode="" Description="Ven0m database name" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="KryTek Database Name" Target="KRYTEK_DB_NAME" Default="KryTek" Mode="" Description="KryTek database name" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="S0b Mart Database Name" Target="S0B_MART_DB_NAME" Default="S0b_Mart" Mode="" Description="S0b Mart database name" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Database Root User" Target="ROOT_USER" Default="root" Mode="" Description="MySQL root username (for admin operations)" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Database Root Password" Target="ROOT_PASSWORD" Default="" Mode="" Description="MySQL root password (for admin operations)" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="Use Environment Config" Target="USE_ENV_CONFIG" Default="true" Mode="" Description="Set to 'true' to use environment variables instead of interactive prompts (required for Docker/Unraid)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Run Interval (Minutes)" Target="RUN_INTERVAL_MINUTES" Default="60" Mode="" Description="Interval in minutes to repeat jobs (0 or empty for single run)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable S0b Wallet Import" Target="ENABLE_S0B_WALLET" Default="true" Mode="" Description="Enable S0b Holdings wallet data import" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable S0b Struct Wallet Import" Target="ENABLE_S0B_STRUCT_WALLET" Default="false" Mode="" Description="Enable S0b Structure Management wallet data import" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable Ven0m Wallet Import" Target="ENABLE_VEN0M_WALLET" Default="false" Mode="" Description="Enable Ven0m wallet data import" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable KryTek Wallet Import" Target="ENABLE_KRYTEK_WALLET" Default="false" Mode="" Description="Enable KryTek wallet data import" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable S0b Mart Wallet Import" Target="ENABLE_S0B_MART_WALLET" Default="false" Mode="" Description="Enable S0b-Mart wallet data import" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable S0b Struct Contracts Import" Target="ENABLE_S0B_STRUCT_CONTRACTS" Default="false" Mode="" Description="Enable S0b_Struct contracts import" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable CSV Import" Target="ENABLE_CSV_IMPORT" Default="false" Mode="" Description="Enable CSV data import to database" Type="Variable" Display="advanced" Required="false" Mask="false"/>
</Container>
