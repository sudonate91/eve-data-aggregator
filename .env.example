# EVE Online ESI API Configuration
CLIENT_ID=your-client-id
CALLBACK_URL=http://<your-ip>:3000/callback
SCOPE="esi-wallet.read_corporation_wallets.v1 esi-contracts.read_corporation_contracts.v1"
STATE=unique-state

# Corporation IDs
CORPORATION_ID=your-corporation-id
STRUCT_CORPORATION_ID=your-struct-corp-id
VEN0M_CORPORATION_ID=your-ven0m-corp-id
KRYTEK_CORPORATION_ID=your-krytek-corp-id
S0B_MART_CORPORATION_ID=your-s0b-mart-corp-id

# Janice API
JANICE_API_KEY=your-janice-api-key

# Auth web UI — open http://<your-ip>:AUTH_PORT to authenticate corps via browser
AUTH_PORT=3000

# Database Configuration
# DB_HOST=eve-mysql        when using the bundled eve-mysql container (docker compose or Unraid two-container)
# DB_HOST=127.0.0.1       when connecting to an external MySQL on the same host
DB_HOST=eve-mysql
DB_PORT=3306
DB_USER=S0b_Admin
DB_PASSWORD=your-db-password
DB_NAME=S0b
S0b_STRUCT_DB_NAME=S0b_Struct
VEN0M_DB_NAME=Ven0m
KRYTEK_DB_NAME=KryTek
S0B_MART_DB_NAME=S0b_Mart

# MySQL container root password (must match MYSQL_ROOT_PASSWORD on the eve-mysql container)
# Also used by db/migrate.sh for importing dumps
MYSQL_ROOT_PASSWORD=your-root-password
ROOT_USER=root
ROOT_PASSWORD=your-root-password

# Read-only user password for PowerBI / MySQL Workbench / reporting tools
# User: eve_readonly  Password: value below
# If left blank or unset, eve_readonly gets the same password as DB_PASSWORD
# PowerBI connection: Host=<unraid-ip>  Port=3307  User=eve_readonly
MYSQL_READONLY_PASSWORD=your-readonly-password

# MySQL Workbench / external tool access:
# Connect to <host-ip>:3307 (host port mapped from the eve-mysql container's 3306)

# Docker/Unraid Non-Interactive Mode Configuration
# Set to 'true' to use environment variables instead of interactive prompts
USE_ENV_CONFIG=true

# Run Interval (in minutes) - Leave empty or 0 for single run, or set to desired interval
RUN_INTERVAL_MINUTES=60

# Enable/Disable Jobs (set to 'true' to enable each job)
ENABLE_S0B_WALLET=true
ENABLE_S0B_STRUCT_WALLET=true
ENABLE_VEN0M_WALLET=true
ENABLE_KRYTEK_WALLET=true
ENABLE_S0B_MART_WALLET=true
ENABLE_S0B_STRUCT_CONTRACTS=true
ENABLE_CSV_IMPORT=false
