# Local Development Environment (Native Node.js)
# Copy to .env.local and configure your values
# Usage: npm run dev (automatically loads this file)

# EVE Online ESI API Configuration
CLIENT_ID=your-client-id
CALLBACK_URL=http://localhost:3000/callback/
SCOPE="esi-wallet.read_corporation_wallets.v1 esi-contracts.read_corporation_contracts.v1"
STATE=unique-state

# Corporation IDs (S0b and affiliated)
CORPORATION_ID=98399918
STRUCT_CORPORATION_ID=98782550
VEN0M_CORPORATION_ID=98628586
KRYTEK_CORPORATION_ID=1108900188
S0B_MART_CORPORATION_ID=98830670

# Janice API
JANICE_API_KEY=your-janice-api-key

# Database Configuration (points to dev MySQL on port 3307)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=S0b_Admin
DB_PASSWORD=devpassword
DB_NAME=S0b
S0b_STRUCT_DB_NAME=S0b_Struct
VEN0M_DB_NAME=Ven0m
KRYTEK_DB_NAME=KryTek
S0B_MART_DB_NAME=S0b_Mart

# Admin credentials
ROOT_USER=root
ROOT_PASSWORD=devroot

# Read-only user for PowerBI / reporting tools (auto-created on startup)
# Defaults to DB_PASSWORD if not set
MYSQL_READONLY_PASSWORD=devpassword

# Runtime Configuration
USE_ENV_CONFIG=true
RUN_INTERVAL_MINUTES=0

# Job Toggles
ENABLE_S0B_WALLET=true
ENABLE_S0B_STRUCT_WALLET=true
ENABLE_VEN0M_WALLET=true
ENABLE_KRYTEK_WALLET=true
ENABLE_S0B_MART_WALLET=true
ENABLE_S0B_STRUCT_CONTRACTS=true
ENABLE_CSV_IMPORT=false
